{
  "name": "@bounded-systems/github-budget",
  "version": "0.1.1",
  "description": "Rate-limit-aware gh wrapper with bucket classification, pre-call gating, and audit trail",
  "bounded": {
    "tagline": "Rate-limit-aware gh wrapper with bucket classification, pre-call gating, and audit trail",
    "kind": "door",
    "facet": "verb",
    "role": "governor",
    "domain": "github/rate-limit"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/github-budget.git"
  },
  "homepage": "https://github.com/bounded-systems/github-budget#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/github-budget/issues"
  },
  "keywords": [
    "github",
    "rate-limit",
    "budget",
    "audit",
    "gating"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "schema:gen": "bun run scripts/gen-schema-types.ts",
    "schema:check": "bun run scripts/gen-schema-types.ts --check"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@bounded-systems/audit-context": "npm:@jsr/bounded-systems__audit-context@^0.2.1",
    "@bounded-systems/env": "npm:@jsr/bounded-systems__env@^0.2.0",
    "@bounded-systems/proc": "npm:@jsr/bounded-systems__proc@^0.2.3"
  }
}
