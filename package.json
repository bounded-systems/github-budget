{
  "name": "@bounded-systems/github-budget",
  "version": "0.1.0",
  "description": "Rate-limit-aware gh wrapper with bucket classification, pre-call gating, and audit trail",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/github-budget.git"
  },
  "homepage": "https://github.com/bounded-systems/github-budget#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/github-budget/issues"
  },
  "keywords": [
    "github",
    "rate-limit",
    "budget",
    "audit",
    "gating"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bounded-systems/audit-context": "workspace:*",
    "@bounded-systems/env": "workspace:*",
    "@bounded-systems/proc": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  }
}
